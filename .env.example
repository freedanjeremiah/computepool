X402_FACILITATOR_URL=http://facilitator:4021
X402_DEFAULT_PRICE_PER_TOKEN_USDC_MICRO=100

# =====================================================================
# Orchestrator wallet (x402 payee, KH wallet integration owner)
# =====================================================================
ORCHESTRATOR_WALLET_ADDRESS=0xREPLACE_WITH_ORCHESTRATOR_WALLET

# =====================================================================
