{
  "name": "compute-coalition-activate-and-pool",
  "description": "Activate the on-chain coalition (after orchestrator confirms all worker sign txs landed), create the GDA payment pool, assign initial member units, and call back so orchestrator can drive workers' connectPool. v1 demo: 2 fixed participant slots.",
  "enabled": true,
  "nodes": [
    {
      "id": "trigger",
      "type": "trigger",
      "position": {"x": 100, "y": 200},
      "data": {
        "type": "trigger",
        "label": "Trigger",
        "config": {
          "triggerType": "Manual",
          "inputs": {
            "session_id": {"type": "string"},
            "coalition_address": {"type": "string"},
            "onchain_id": {"type": "string"},
            "super_token": {"type": "string"},
            "pool_admin": {"type": "string"},
            "participant_a": {"type": "string"},
            "units_a": {"type": "string"},
            "participant_b": {"type": "string"},
            "units_b": {"type": "string"},
            "callback_url": {"type": "string"}
          }
        }
      }
    },
    {
      "id": "activate",
      "type": "action",
      "position": {"x": 350, "y": 200},
      "data": {
        "type": "action",
        "label": "Coalition.activate",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "{{@trigger:Trigger.body.coalition_address}}",
          "abiFunction": "activate",
          "abi": "[{\"name\":\"activate\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"coalitionId\",\"type\":\"uint256\"}],\"outputs\":[]}]",
          "functionArgs": "[\"{{@trigger:Trigger.body.onchain_id}}\"]",
          "gasLimitMultiplier": "1.2"
        }
      }
    },
    {
      "id": "create-pool",
      "type": "action",
      "position": {"x": 600, "y": 200},
      "data": {
        "type": "action",
        "label": "GDA createPool",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "0x6DA13Bde224A05a288748d857b9e7DDEffd1dE08",
          "abiFunction": "createPool",
          "abi": "[{\"name\":\"createPool\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"token\",\"type\":\"address\"},{\"name\":\"admin\",\"type\":\"address\"},{\"name\":\"config\",\"type\":\"tuple\",\"components\":[{\"name\":\"transferabilityForUnitsOwner\",\"type\":\"bool\"},{\"name\":\"distributionFromAnyAddress\",\"type\":\"bool\"}]}],\"outputs\":[{\"name\":\"success\",\"type\":\"bool\"},{\"name\":\"pool\",\"type\":\"address\"}]}]",
          "functionArgs": "[\"{{@trigger:Trigger.body.super_token}}\",\"{{@trigger:Trigger.body.pool_admin}}\",[false,false]]",
          "gasLimitMultiplier": "1.3"
        }
      }
    },
    {
      "id": "units-a",
      "type": "action",
      "position": {"x": 850, "y": 100},
      "data": {
        "type": "action",
        "label": "GDA updateMemberUnits A",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "0x6DA13Bde224A05a288748d857b9e7DDEffd1dE08",
          "abiFunction": "updateMemberUnits",
          "abi": "[{\"name\":\"updateMemberUnits\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"pool\",\"type\":\"address\"},{\"name\":\"memberAddress\",\"type\":\"address\"},{\"name\":\"newUnits\",\"type\":\"uint128\"},{\"name\":\"userData\",\"type\":\"bytes\"}],\"outputs\":[{\"type\":\"bool\"}]}]",
          "functionArgs": "[\"{{@create-pool:GDA createPool.result.pool}}\",\"{{@trigger:Trigger.body.participant_a}}\",\"{{@trigger:Trigger.body.units_a}}\",\"0x\"]",
          "gasLimitMultiplier": "1.2"
        }
      }
    },
    {
      "id": "units-b",
      "type": "action",
      "position": {"x": 850, "y": 300},
      "data": {
        "type": "action",
        "label": "GDA updateMemberUnits B",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "0x6DA13Bde224A05a288748d857b9e7DDEffd1dE08",
          "abiFunction": "updateMemberUnits",
          "abi": "[{\"name\":\"updateMemberUnits\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"pool\",\"type\":\"address\"},{\"name\":\"memberAddress\",\"type\":\"address\"},{\"name\":\"newUnits\",\"type\":\"uint128\"},{\"name\":\"userData\",\"type\":\"bytes\"}],\"outputs\":[{\"type\":\"bool\"}]}]",
          "functionArgs": "[\"{{@create-pool:GDA createPool.result.pool}}\",\"{{@trigger:Trigger.body.participant_b}}\",\"{{@trigger:Trigger.body.units_b}}\",\"0x\"]",
          "gasLimitMultiplier": "1.2"
        }
      }
    },
    {
      "id": "callback",
      "type": "action",
      "position": {"x": 1150, "y": 200},
      "data": {
        "type": "action",
        "label": "POST payment_pool_ready",
        "config": {
          "actionType": "HTTP Request",
          "httpMethod": "POST",
          "endpoint": "{{@trigger:Trigger.body.callback_url}}",
          "httpHeaders": "{\"Content-Type\":\"application/json\"}",
          "httpBody": "{\"event\":\"payment_pool_ready\",\"session_id\":\"{{@trigger:Trigger.body.session_id}}\",\"pool_address\":\"{{@create-pool:GDA createPool.result.pool}}\",\"super_token\":\"{{@trigger:Trigger.body.super_token}}\",\"activate_tx\":\"{{@activate:Coalition.activate.transactionHash}}\",\"create_pool_tx\":\"{{@create-pool:GDA createPool.transactionHash}}\",\"units_a_tx\":\"{{@units-a:GDA updateMemberUnits A.transactionHash}}\",\"units_b_tx\":\"{{@units-b:GDA updateMemberUnits B.transactionHash}}\"}"
        }
      }
    }
  ],
  "edges": [
    {"id": "e1", "source": "trigger", "target": "activate"},
    {"id": "e2", "source": "activate", "target": "create-pool"},
    {"id": "e3", "source": "create-pool", "target": "units-a"},
    {"id": "e4", "source": "units-a", "target": "units-b"},
    {"id": "e5", "source": "units-b", "target": "callback"}
  ]
}
