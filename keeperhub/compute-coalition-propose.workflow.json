{
  "name": "compute-coalition-propose",
  "description": "Propose a new coalition on Coalition.sol. Returns the on-chain coalitionId via callback. Workers then sign via their own keys; orchestrator triggers compute-coalition-activate-and-pool once all sigs land.",
  "enabled": true,
  "nodes": [
    {
      "id": "trigger",
      "type": "trigger",
      "position": {"x": 100, "y": 200},
      "data": {
        "type": "trigger",
        "label": "Trigger",
        "config": {
          "triggerType": "Manual",
          "inputs": {
            "session_id": {"type": "string"},
            "coalition_address": {"type": "string"},
            "participants": {"type": "string"},
            "terms_hash": {"type": "string"},
            "deadline_unix": {"type": "string"},
            "stake_token": {"type": "string"},
            "stake_per_party": {"type": "string"},
            "callback_url": {"type": "string"}
          }
        }
      }
    },
    {
      "id": "propose",
      "type": "action",
      "position": {"x": 400, "y": 200},
      "data": {
        "type": "action",
        "label": "Coalition.propose",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "{{@trigger:Trigger.body.coalition_address}}",
          "abiFunction": "propose",
          "abi": "[{\"name\":\"propose\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"participants\",\"type\":\"address[]\"},{\"name\":\"termsHash\",\"type\":\"bytes32\"},{\"name\":\"deadline\",\"type\":\"uint256\"},{\"name\":\"stakeToken\",\"type\":\"address\"},{\"name\":\"stakePerParty\",\"type\":\"uint256\"}],\"outputs\":[{\"name\":\"coalitionId\",\"type\":\"uint256\"}]}]",
          "functionArgs": "[{{@trigger:Trigger.body.participants}},\"{{@trigger:Trigger.body.terms_hash}}\",\"{{@trigger:Trigger.body.deadline_unix}}\",\"{{@trigger:Trigger.body.stake_token}}\",\"{{@trigger:Trigger.body.stake_per_party}}\"]",
          "gasLimitMultiplier": "1.2"
        }
      }
    },
    {
      "id": "callback",
      "type": "action",
      "position": {"x": 700, "y": 200},
      "data": {
        "type": "action",
        "label": "POST coalition_proposed",
        "config": {
          "actionType": "HTTP Request",
          "httpMethod": "POST",
          "endpoint": "{{@trigger:Trigger.body.callback_url}}",
          "httpHeaders": "{\"Content-Type\":\"application/json\"}",
          "httpBody": "{\"event\":\"coalition_proposed\",\"session_id\":\"{{@trigger:Trigger.body.session_id}}\",\"tx_hash\":\"{{@propose:Coalition.propose.transactionHash}}\",\"onchain_id\":\"{{@propose:Coalition.propose.result}}\"}"
        }
      }
    }
  ],
  "edges": [
    {"id": "e1", "source": "trigger", "target": "propose"},
    {"id": "e2", "source": "propose", "target": "callback"}
  ]
}
