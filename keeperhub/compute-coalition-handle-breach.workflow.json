{
  "name": "compute-coalition-handle-breach",
  "description": "Placeholder for breach + slash + member-units-zero. Wired in v1 but not exercised; workflow shape locked in for future use.",
  "enabled": false,
  "nodes": [
    {
      "id": "trigger",
      "type": "trigger",
      "position": {"x": 100, "y": 200},
      "data": {
        "type": "trigger",
        "label": "Trigger",
        "config": {
          "triggerType": "Manual",
          "inputs": {
            "session_id": {"type": "string"},
            "coalition_address": {"type": "string"},
            "onchain_id": {"type": "string"},
            "breaching_party": {"type": "string"},
            "evidence_hash": {"type": "string"},
            "evidence_uri": {"type": "string"},
            "super_token": {"type": "string"},
            "pool_address": {"type": "string"},
            "sender": {"type": "string"},
            "callback_url": {"type": "string"}
          }
        }
      }
    },
    {
      "id": "record-breach",
      "type": "action",
      "position": {"x": 400, "y": 100},
      "data": {
        "type": "action",
        "label": "Coalition.recordBreach",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "{{@trigger:Trigger.body.coalition_address}}",
          "abiFunction": "recordBreach",
          "abi": "[{\"name\":\"recordBreach\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"coalitionId\",\"type\":\"uint256\"},{\"name\":\"party\",\"type\":\"address\"},{\"name\":\"evidenceHash\",\"type\":\"bytes32\"}],\"outputs\":[]}]",
          "functionArgs": "[\"{{@trigger:Trigger.body.onchain_id}}\",\"{{@trigger:Trigger.body.breaching_party}}\",\"{{@trigger:Trigger.body.evidence_hash}}\"]",
          "gasLimitMultiplier": "1.2"
        }
      }
    },
    {
      "id": "slash",
      "type": "action",
      "position": {"x": 700, "y": 100},
      "data": {
        "type": "action",
        "label": "Coalition.slash",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "{{@trigger:Trigger.body.coalition_address}}",
          "abiFunction": "slash",
          "abi": "[{\"name\":\"slash\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"coalitionId\",\"type\":\"uint256\"},{\"name\":\"party\",\"type\":\"address\"}],\"outputs\":[]}]",
          "functionArgs": "[\"{{@trigger:Trigger.body.onchain_id}}\",\"{{@trigger:Trigger.body.breaching_party}}\"]",
          "gasLimitMultiplier": "1.5"
        }
      }
    },
    {
      "id": "zero-units",
      "type": "action",
      "position": {"x": 1000, "y": 100},
      "data": {
        "type": "action",
        "label": "GDA updateMemberUnits to 0",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "REPLACE_WITH_YOUR_WALLET_INTEGRATION_ID",
          "network": "11155111",
          "contractAddress": "0x6DA13Bde224A05a288748d857b9e7DDEffd1dE08",
          "abiFunction": "updateMemberUnits",
          "abi": "[{\"name\":\"updateMemberUnits\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"pool\",\"type\":\"address\"},{\"name\":\"memberAddress\",\"type\":\"address\"},{\"name\":\"newUnits\",\"type\":\"uint128\"},{\"name\":\"userData\",\"type\":\"bytes\"}],\"outputs\":[{\"type\":\"bool\"}]}]",
          "functionArgs": "[\"{{@trigger:Trigger.body.pool_address}}\",\"{{@trigger:Trigger.body.breaching_party}}\",\"0\",\"0x\"]",
          "gasLimitMultiplier": "1.2"
        }
      }
    },
    {
      "id": "callback",
      "type": "action",
      "position": {"x": 1300, "y": 100},
      "data": {
        "type": "action",
        "label": "POST breach_slashed",
        "config": {
          "actionType": "HTTP Request",
          "httpMethod": "POST",
          "endpoint": "{{@trigger:Trigger.body.callback_url}}",
          "httpHeaders": "{\"Content-Type\":\"application/json\"}",
          "httpBody": "{\"event\":\"breach_slashed\",\"session_id\":\"{{@trigger:Trigger.body.session_id}}\",\"breaching_party\":\"{{@trigger:Trigger.body.breaching_party}}\",\"slash_tx\":\"{{@slash:Coalition.slash.transactionHash}}\",\"units_zero_tx\":\"{{@zero-units:GDA updateMemberUnits to 0.transactionHash}}\"}"
        }
      }
    }
  ],
  "edges": [
    {"id": "e1", "source": "trigger", "target": "record-breach"},
    {"id": "e2", "source": "record-breach", "target": "slash"},
    {"id": "e3", "source": "slash", "target": "zero-units"},
    {"id": "e4", "source": "zero-units", "target": "callback"}
  ]
}
